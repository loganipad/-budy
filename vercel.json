{
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.auth0.com https://cdn.jsdelivr.net blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://*.auth0.com https://api.stripe.com blob:; frame-src 'self' https://*.auth0.com https://js.stripe.com; worker-src 'self' blob:; object-src 'none'; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://*.auth0.com https://checkout.stripe.com"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/create-checkout-session",
      "destination": "/api/subscription?action=checkout"
    },
    {
      "source": "/api/create-billing-portal-session",
      "destination": "/api/subscription?action=billing-portal"
    },
    {
      "source": "/api/cancel-subscription-now",
      "destination": "/api/subscription?action=cancel"
    },
    {
      "source": "/api/issue-test-session",
      "destination": "/api/test-engine?action=issue"
    },
    {
      "source": "/api/evaluate-answer",
      "destination": "/api/test-engine?action=evaluate"
    },
    {
      "source": "/api/grade-test",
      "destination": "/api/test-engine?action=grade"
    },
    {
      "source": "/data/question-bank/(.*)",
      "destination": "/404.html"
    },
    {
      "source": "/404",
      "destination": "/404.html"
    },
    {
      "source": "/study",
      "destination": "/study.html"
    },
    {
      "source": "/my-account",
      "destination": "/my-account.html"
    },
    {
      "source": "/score-guarantee",
      "destination": "/score-guarantee.html"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/contact",
      "destination": "/contact.html"
    },
    {
      "source": "/checkout",
      "destination": "/checkout.html"
    },
    {
      "source": "/free-trial",
      "destination": "/index.html?source=free-trial"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    }
  ]
}
